# =============================================================================
# Spotify Review Discovery Engine — Environment Configuration
# =============================================================================
# Copy this file to `.env` and fill in your values:
#   cp .env.example .env        (Linux/macOS)
#   copy .env.example .env      (Windows)
#
# Never commit `.env` — it contains secrets.
# =============================================================================


# -----------------------------------------------------------------------------
# Supabase (Required)
# https://supabase.com/dashboard → Project Settings → API
# -----------------------------------------------------------------------------

# Project URL (e.g. https://xxxxxxxxxxxx.supabase.co)
SUPABASE_URL=

# Service role key (secret — server-side only, bypasses RLS)
SUPABASE_SERVICE_KEY=


# -----------------------------------------------------------------------------
# LLM Provider (Required — default: Google Gemini)
# https://aistudio.google.com/apikey
# -----------------------------------------------------------------------------

# Active generative LLM backend: gemini | openai
LLM_PROVIDER=gemini

# Google Gemini (required when LLM_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenAI (only when LLM_PROVIDER=openai — optional swap)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o


# -----------------------------------------------------------------------------
# Embeddings (Required — default: Google Gemini)
# -----------------------------------------------------------------------------

# Active embedding backend: gemini | openai
EMBEDDING_PROVIDER=gemini

# Gemini embeddings (default — 768 dimensions)
GEMINI_EMBEDDING_MODEL=text-embedding-004
EMBEDDING_DIMENSIONS=768

# OpenAI embeddings (only when EMBEDDING_PROVIDER=openai — optional swap)
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# EMBEDDING_DIMENSIONS=1536


# -----------------------------------------------------------------------------
# Reddit — Public JSON API (Required for live Reddit ingestion)
# No Reddit app, client ID, or client secret needed.
# -----------------------------------------------------------------------------

# Descriptive User-Agent — Reddit rejects empty/default agents.
# Replace with your contact email or Reddit username.
REDDIT_USER_AGENT=spotify-review-engine/1.0 (contact: your@email.com)

# Seconds to wait between Reddit JSON API requests (avoid 429 rate limits)
REDDIT_REQUEST_DELAY_SECONDS=7


# -----------------------------------------------------------------------------
# App Store / Play Store targets (Optional — defaults shown)
# -----------------------------------------------------------------------------

# Google Play Store app ID for Spotify
SPOTIFY_PLAY_STORE_APP_ID=com.spotify.music

# Apple App Store numeric app ID for Spotify
SPOTIFY_APP_STORE_APP_ID=324684580


# -----------------------------------------------------------------------------
# Ingestion targets (Optional — defaults shown)
# Minimum records to collect per source during a full pipeline run
# -----------------------------------------------------------------------------

MIN_REVIEWS_PLAYSTORE=500
MIN_REVIEWS_APPSTORE=300
MIN_REVIEWS_REDDIT=200


# -----------------------------------------------------------------------------
# AI pipeline tuning (Optional — defaults shown)
# -----------------------------------------------------------------------------

# Reviews processed per LLM batch during per-review analysis
ANALYSIS_BATCH_SIZE=15

# Minimum new reviews before collective analysis (themes, segments, etc.) re-runs
COLLECTIVE_ANALYSIS_THRESHOLD=50

# Minimum confidence score (0–1) for reviews included in RAG retrieval
RAG_MIN_CONFIDENCE=0.5

# Number of similar reviews retrieved for Research Assistant context
RAG_TOP_K=15
