# Local Streamlit secrets template (Phase 4.5.4)
# Copy to `.streamlit/secrets.toml` for local dev, or paste into Streamlit Cloud dashboard.
# Never commit secrets.toml — it is gitignored.

SUPABASE_URL = "https://xxxxxxxxxxxx.supabase.co"
SUPABASE_SERVICE_KEY = "your-service-role-key"

LLM_PROVIDER = "groq"
GROQ_API_KEY = "gsk_..."
GROQ_MODEL = "llama-3.3-70b-versatile"

# Required for embeddings (default provider)
EMBEDDING_PROVIDER = "gemini"
GEMINI_API_KEY = "your-gemini-api-key"
GEMINI_EMBEDDING_MODEL = "gemini-embedding-001"
EMBEDDING_DIMENSIONS = "768"

# Optional: swap LLM to Gemini for production
# LLM_PROVIDER = "gemini"
# GEMINI_MODEL = "gemini-2.5-flash"

REDDIT_USER_AGENT = "spotify-review-engine/1.0 (contact: your@email.com)"
REDDIT_REQUEST_DELAY_SECONDS = "7"

SPOTIFY_PLAY_STORE_APP_ID = "com.spotify.music"
SPOTIFY_APP_STORE_APP_ID = "324684580"
