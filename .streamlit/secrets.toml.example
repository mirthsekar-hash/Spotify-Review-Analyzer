# Local Streamlit secrets template (Phase 4.5.4)
# Paste into Streamlit Cloud: Manage app → Secrets (TOML editor). Reboot after saving.
# Never commit secrets.toml — it is gitignored.

# --- Option A: flat keys (recommended) ---
SUPABASE_URL = "https://xxxxxxxxxxxx.supabase.co"
SUPABASE_SERVICE_KEY = "your-service-role-key"

LLM_PROVIDER = "groq"
GROQ_API_KEY = "gsk_..."
GROQ_MODEL = "llama-3.3-70b-versatile"

EMBEDDING_PROVIDER = "gemini"
GEMINI_API_KEY = "your-gemini-api-key"
GEMINI_EMBEDDING_MODEL = "gemini-embedding-001"
EMBEDDING_DIMENSIONS = "768"

REDDIT_USER_AGENT = "spotify-review-engine/1.0 (contact: your@email.com)"
REDDIT_REQUEST_DELAY_SECONDS = "7"

# --- Option B: nested sections (also supported) ---
# [supabase]
# url = "https://xxxxxxxxxxxx.supabase.co"
# service_key = "your-service-role-key"
#
# [groq]
# api_key = "gsk_..."
#
# [gemini]
# api_key = "your-gemini-api-key"